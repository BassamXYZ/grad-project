<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- <xacro:include filename="inertial_macros.xacro"/> -->
 
    <xacro:property name="chassis_length" value="0.4"/>
    <xacro:property name="chassis_width" value="0.3"/>
    <xacro:property name="chassis_height" value="0.15"/>
    <xacro:property name="chassis_mass" value="10.0"/>
    <xacro:property name="wheel_radius" value="0.06"/>
    <xacro:property name="wheel_thickness" value="0.03"/>
    <xacro:property name="wheel_mass" value="0.5"/>
    <!--
    <xacro:property name="wheel_offset_x" value="0.226"/>
    <xacro:property name="wheel_offset_y" value="0.1485"/>
    <xacro:property name="wheel_offset_z" value="0.01"/>
    -->


  <!-- ===== MATERIALS ===== -->
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
    <material name="white">
        <color rgba="1 1 1 1" />
    </material>
    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>
    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>
    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

  <!-- ===== BASE LINK: CHASSIS ===== -->

    <!--
        BASE_FOOTPRINT LINK 
      <joint name="base_footprint_joint" type="fixed">
          <parent link="base_link"/>
          <child link="base_footprint"/>
          <origin xyz="0 0 0" rpy="0 0 0"/>
      </joint>
      <link name="base_footprint">
      </link>
    -->

  <link name="chassis">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${chassis_mass}"/>
      <!-- Inertia for a uniform box: Ixx = (m/12)*(y^2+z^2), etc. -->
      <inertia ixx="0.09375" ixy="0.0" ixz="0.0"
               iyy="0.15208" iyz="0.0"
               izz="0.20833"/>
    </inertial>
    <!-- <xacro:inertial_box mass="0.5" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}">
            <origin xyz="${chassis_length/2} 0 ${chassis_height/2}" rpy="0 0 0"/>
         </xacro:inertial_box> -->
  </link>

    <gazebo reference="chassis">
        <material>Ignition/Orange</material>
    </gazebo>

 <!-- ===== DRIVE WHEELS ===== -->
  <!-- Left drive wheel -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${wheel_mass}"/>
      <!-- Cylinder axis along y: Iyy = 0.5*m*r^2, Ixx = Izz = (m/12)*(3r^2 + L^2) -->
      <inertia ixx="0.0004875" ixy="0.0" ixz="0.0"
               iyy="0.0009"    iyz="0.0"
               izz="0.0004875"/>
    </inertial>
    <!-- <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_thickness}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
         </xacro:inertial_cylinder> -->
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="left_wheel"/>
    <origin xyz="0 -0.165 -0.055" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <gazebo reference="left_wheel">
      <material>Ignition/Blue</material>
  </gazebo>

 <!-- Right drive wheel -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0004875" ixy="0.0" ixz="0.0"
               iyy="0.0009"    iyz="0.0"
               izz="0.0004875"/>
    </inertial>
    <!-- <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_thickness}" radius="${wheel_radius}">
            <origin xyz="0 0 0" rpy="0 0 0"/>
         </xacro:inertial_cylinder> -->
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="right_wheel"/>
    <origin xyz="0 0.165 -0.055" rpy="${pi/2} 0 0"/>
    <!-- <origin xyz="0 ${wheel_offset_y} 0" rpy="${pi/2} 0 0" /> -->
    <axis xyz="0 1 0"/>
  </joint>
  <gazebo reference="right_wheel">
      <material>Ignition/Blue</material>
  </gazebo>

  <!-- ===== SUPPORT WHEELS (casters, modeled as spheres) ===== -->
  <!-- Front left corner (x = +0.2, y = +0.15) -->
  <link name="support_front_left">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <!-- Solid sphere inertia: (2/5)*m*r^2 -->
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  <joint name="support_front_left_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_front_left"/>
    <origin xyz="0.2 0.15 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- Front right corner (x = +0.2, y = -0.15) -->
  <link name="support_front_right">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  <joint name="support_front_right_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_front_right"/>
    <origin xyz="0.2 -0.15 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- Back left corner (x = -0.2, y = +0.15) -->
  <link name="support_back_left">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  <joint name="support_back_left_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_back_left"/>
    <origin xyz="-0.2 0.15 -0.095" rpy="0 0 0"/>
  </joint>

  <!-- Back right corner (x = -0.2, y = -0.15) -->
  <link name="support_back_right">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  <joint name="support_back_right_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_back_right"/>
    <origin xyz="-0.2 -0.15 -0.095" rpy="0 0 0"/>
  </joint>
</robot>
