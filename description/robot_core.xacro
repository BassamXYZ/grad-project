<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
 
    <xacro:property name="chassis_length" value="0.4"/>
    <xacro:property name="chassis_width" value="0.3"/>
    <xacro:property name="chassis_height" value="0.15"/>
    <xacro:property name="chassis_mass" value="10.0"/>
    <xacro:property name="wheel_radius" value="0.06"/>
    <xacro:property name="wheel_thickness" value="0.03"/>
    <xacro:property name="wheel_mass" value="0.5"/>
    <!--
    <xacro:property name="wheel_offset_x" value=""/>
    <xacro:property name="wheel_offset_y" value=""/>
    <xacro:property name="wheel_offset_z" value=""/>
    -->


  <!-- ===== MATERIALS ===== -->
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
    <material name="white">
        <color rgba="1 1 1 1" />
    </material>
    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>
    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>
    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>
    
    
  <!-- ===== ROOT LINK ===== -->
    
  <link name="base_link"></link>

  <joint name="base_link_chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0.115" rpy="0 0 0"/>
  </joint>


  <!-- ===== BASE LINK: CHASSIS ===== -->
  
  <link name="chassis">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${chassis_mass}"/>
      <inertia ixx="0.09375" ixy="0.0" ixz="0.0"
               iyy="0.15208" iyz="0.0"
               izz="0.20833"/>
    </inertial>
  </link>

    <gazebo reference="chassis">
        <material>Gazebo/Orange</material>
    </gazebo>

 <!-- ===== DRIVE WHEELS ===== -->
  <!-- Left drive wheel -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0004875" ixy="0.0" ixz="0.0"
               iyy="0.0009"    iyz="0.0"
               izz="0.0004875"/>
    </inertial>
  </link>
  
  <joint name="left_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="left_wheel"/>
    <origin xyz="0 -0.165 -0.055" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="left_wheel">
      <material>Gazebo/Blue</material>
  </gazebo>

 <!-- Right drive wheel -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0004875" ixy="0.0" ixz="0.0"
               iyy="0.0009"    iyz="0.0"
               izz="0.0004875"/>
    </inertial>
  </link>
  
  <joint name="right_wheel_joint" type="continuous">
    <parent link="chassis"/>
    <child link="right_wheel"/>
    <origin xyz="0 0.165 -0.055" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <gazebo reference="right_wheel">
      <material>Gazebo/Blue</material>
  </gazebo>

  <!-- ===== SUPPORT WHEELS (casters, modeled as spheres) ===== -->
  <!-- Front left corner (x = +0.2, y = +0.15) -->
  <link name="support_front_left">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  
  <joint name="support_front_left_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_front_left"/>
    <origin xyz="0.2 0.15 -0.095" rpy="0 0 0"/>
  </joint>
  
  <gazebo reference="support_front_left">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>

  <!-- Front right corner (x = +0.2, y = -0.15) -->
  <link name="support_front_right">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  
  <joint name="support_front_right_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_front_right"/>
    <origin xyz="0.2 -0.15 -0.095" rpy="0 0 0"/>
  </joint>

  <gazebo reference="support_front_right">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>

  <!-- Back left corner (x = -0.2, y = +0.15) -->
  <link name="support_back_left">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  
  <joint name="support_back_left_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_back_left"/>
    <origin xyz="-0.2 0.15 -0.095" rpy="0 0 0"/>
  </joint>

  <gazebo reference="support_back_left">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>

  <!-- Back right corner (x = -0.2, y = -0.15) -->
  <link name="support_back_right">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.000016" ixy="0.0" ixz="0.0"
               iyy="0.000016" iyz="0.0"
               izz="0.000016"/>
    </inertial>
  </link>
  
  <joint name="support_back_right_joint" type="fixed">
    <parent link="chassis"/>
    <child link="support_back_right"/>
    <origin xyz="-0.2 -0.15 -0.095" rpy="0 0 0"/>
  </joint>
  
  <gazebo reference="support_back_right">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>
</robot>
